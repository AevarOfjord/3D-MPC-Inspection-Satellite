# Satellite Control System - Environment Variables
# Copy this file to .env and adjust values as needed.

# Headless mode: set to 0 to enable matplotlib GUI windows
SATELLITE_HEADLESS=1

# Dashboard server
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000

# FFmpeg path override (auto-detected if not set)
# FFMPEG_PATH=/usr/local/bin/ffmpeg
